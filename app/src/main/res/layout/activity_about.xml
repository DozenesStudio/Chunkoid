<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/minecraft_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/button_container"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    app:title="@string/about"
                    app:titleTextColor="@color/white"
                    app:navigationIcon="?attr/homeAsUpIndicator"
                    app:navigationIconTint="@color/white">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_about"
                        android:tint="@color/white"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp" />

                </com.google.android.material.appbar.MaterialToolbar>

            </com.google.android.material.appbar.AppBarLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="App Logo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="30sp"
                    android:fontFamily="@font/uranus_pixel"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_version"
                    android:textColor="@color/minecraft_green"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/minecraft_surface_glass"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="By Dozener"
                        android:textColor="@color/minecraft_green"
                        android:textSize="20sp"
                        android:textStyle="italic"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_author"
                            android:layout_width="25dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Author"
                            android:src="@drawable/author" />

                        <ImageView
                            android:id="@+id/iv_bilibili"
                            android:layout_width="34dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="Bilibili"
                            android:src="@drawable/bilibili" />

                        <ImageView
                            android:id="@+id/iv_github"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Github"
                            android:src="@drawable/github" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/minecraft_surface_glass"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_intro"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:id="@+id/tv_chunker_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_credits_chunker"
                        android:textColor="@color/minecraft_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:id="@+id/tv_sdk_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_credits_sdk"
                        android:textColor="@color/minecraft_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_thanks"
                        android:textColor="@color/minecraft_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:id="@+id/tv_website_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_website"
                        android:textColor="@color/minecraft_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_date"
                        android:textColor="@color/minecraft_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:gravity="right"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_update"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/check_update"
            app:backgroundTint="@color/minecraft_green"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_donate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/donate"
            app:backgroundTint="@color/minecraft_green"
            app:cornerRadius="8dp"/>

    </LinearLayout>

</RelativeLayout>