<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg"
        android:scaleType="centerCrop"
        android:fitsSystemWindows="false" />

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- Fragment Container for Pages -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Converter Page -->
            <androidx.coordinatorlayout.widget.CoordinatorLayout
                android:id="@+id/converter_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/minecraft_green"/>

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/nestedScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- App Text Logo -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="40dp"
                            android:layout_marginBottom="16dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/app_text"
                                android:layout_width="251dp"
                                android:layout_height="wrap_content"
                                android:contentDescription="App Text"
                                android:src="@drawable/text" />

                        </LinearLayout>

                        <!-- Prepare World Section -->
                        <LinearLayout
                            android:layout_width="360dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Initial Selection State Card -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/card_initial_state"
                                android:layout_width="match_parent"
                                android:layout_height="200dp"
                                android:layout_marginBottom="16dp"
                                app:cardBackgroundColor="@color/minecraft_surface"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="4dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:paddingLeft="3dp"
                                    android:paddingTop="3dp"
                                    android:paddingRight="3dp"
                                    android:paddingBottom="6dp">

                                    <!-- Archive Button -->
                                    <LinearLayout
                                        android:id="@+id/btn_archive"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:id="@+id/iv_archive"
                                            android:layout_width="match_parent"
                                            android:layout_height="0dp"
                                            android:layout_weight="1"
                                            android:contentDescription="Archive"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/archive" />

                                        <TextView
                                            android:id="@+id/tv_archive_label"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="bottom|start"
                                            android:text="@string/archive"
                                            android:textColor="#B4B4B4"
                                            android:textSize="20sp" />

                                    </LinearLayout>

                                    <!-- Folder Button -->
                                    <LinearLayout
                                        android:id="@+id/btn_folder"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:id="@+id/iv_folder"
                                            android:layout_width="match_parent"
                                            android:layout_height="0dp"
                                            android:layout_weight="1"
                                            android:contentDescription="Folder"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/folder" />

                                        <TextView
                                            android:id="@+id/tv_folder_label"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="bottom|start"
                                            android:text="@string/folder"
                                            android:textColor="#B4B4B4"
                                            android:textSize="20sp" />

                                    </LinearLayout>

                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>

                            <!-- World Info State Card -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/card_world_info"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:visibility="gone"
                                app:cardBackgroundColor="@color/minecraft_surface"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="4dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <!-- Extract Progress Layout -->
                                    <LinearLayout
                                        android:id="@+id/layout_extract_progress"
                                        android:layout_width="match_parent"
                                        android:layout_height="100dp"
                                        android:layout_marginBottom="12dp"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:visibility="gone">

                                        <ProgressBar
                                            android:id="@+id/progress_extract"
                                            style="?android:attr/progressBarStyleHorizontal"
                                            android:layout_width="match_parent"
                                            android:layout_height="8dp"
                                            android:layout_marginHorizontal="16dp"
                                            android:indeterminate="false"
                                            android:max="100"
                                            android:progress="0"
                                            android:progressDrawable="@drawable/progress_drawable" />

                                        <TextView
                                            android:id="@+id/tv_extract_progress"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:layout_marginStart="16dp"
                                            android:layout_gravity="start"
                                            android:text="@string/extracting_world"
                                            android:textColor="@color/white"
                                            android:textSize="18sp" />

                                    </LinearLayout>

                                    <!-- World Info Bar -->
                                    <com.google.android.material.card.MaterialCardView
                                        android:id="@+id/card_world_info_bar"
                                        android:layout_width="match_parent"
                                        android:layout_height="100dp"
                                        android:layout_marginBottom="12dp"
                                        app:cardBackgroundColor="@color/minecraft_surface_dark"
                                        app:cardCornerRadius="8dp"
                                        app:cardElevation="0dp">

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:gravity="center_vertical"
                                            android:orientation="horizontal"
                                            android:padding="8dp">

                                            <!-- World Icon -->
                                            <com.google.android.material.imageview.ShapeableImageView
                                                android:id="@+id/iv_world_icon"
                                                android:layout_width="80dp"
                                                android:layout_height="80dp"
                                                android:layout_marginEnd="12dp"
                                                android:background="@color/minecraft_green"
                                                android:scaleType="centerCrop"
                                                android:src="@drawable/unknown"
                                                app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                                                app:strokeColor="@color/transparent"
                                                app:strokeWidth="0dp" />

                                            <!-- World Name -->
                                            <TextView
                                                android:id="@+id/tv_world_name"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:text="世界名称"
                                                android:textColor="@color/white"
                                                android:textSize="24sp"
                                                android:textStyle="bold" />

                                        </LinearLayout>

                                    </com.google.android.material.card.MaterialCardView>

                                    <!-- Info Cards Row -->
                                    <LinearLayout
                                        android:id="@+id/layout_info_cards"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="16dp"
                                        android:gravity="center"
                                        android:orientation="horizontal">

                                        <!-- Platform Card -->
                                        <com.google.android.material.card.MaterialCardView
                                            android:id="@+id/card_platform"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginEnd="8dp"
                                            app:cardBackgroundColor="@color/transparent"
                                            app:cardCornerRadius="6dp"
                                            app:cardElevation="0dp"
                                            app:strokeColor="@color/minecraft_green"
                                            app:strokeWidth="2dp">

                                            <LinearLayout
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:gravity="center"
                                                android:paddingStart="16dp"
                                                android:paddingTop="8dp"
                                                android:paddingEnd="16dp"
                                                android:paddingBottom="8dp">

                                                <TextView
                                                    android:id="@+id/tv_platform"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:text="基岩版"
                                                    android:textColor="@color/white"
                                                    android:textSize="16sp"
                                                    android:textStyle="bold" />

                                            </LinearLayout>

                                        </com.google.android.material.card.MaterialCardView>

                                        <!-- Target Version Card -->
                                        <com.google.android.material.card.MaterialCardView
                                            android:id="@+id/card_target_version"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:visibility="gone"
                                            app:cardBackgroundColor="@color/transparent"
                                            app:cardCornerRadius="6dp"
                                            app:cardElevation="0dp"
                                            app:strokeColor="@color/minecraft_green"
                                            app:strokeWidth="2dp">

                                            <LinearLayout
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:gravity="center"
                                                android:paddingStart="16dp"
                                                android:paddingTop="8dp"
                                                android:paddingEnd="16dp"
                                                android:paddingBottom="8dp">

                                                <TextView
                                                    android:id="@+id/tv_target_version"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:text="转换为 Java 1.20"
                                                    android:textColor="@color/white"
                                                    android:textSize="16sp"
                                                    android:textStyle="bold" />

                                            </LinearLayout>

                                        </com.google.android.material.card.MaterialCardView>

                                        <!-- Version Card (Temporarily Hidden) -->
                                        <com.google.android.material.card.MaterialCardView
                                            android:id="@+id/card_version"
                                            android:layout_width="0dp"
                                            android:layout_height="50dp"
                                            android:layout_marginEnd="8dp"
                                            android:layout_weight="1"
                                            android:visibility="invisible"
                                            app:cardBackgroundColor="@color/minecraft_gold"
                                            app:cardCornerRadius="6dp"
                                            app:cardElevation="0dp">

                                            <LinearLayout
                                                android:layout_width="match_parent"
                                                android:layout_height="match_parent"
                                                android:gravity="center">

                                                <TextView
                                                    android:id="@+id/tv_version"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:text="版本"
                                                    android:textColor="@color/black"
                                                    android:textSize="16sp"
                                                    android:textStyle="bold" />

                                            </LinearLayout>

                                        </com.google.android.material.card.MaterialCardView>

                                    </LinearLayout>

                                    <!-- Conversion Buttons -->
                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btn_select_target"
                                        android:layout_width="match_parent"
                                        android:layout_height="60dp"
                                        android:text="@string/select_target_format"
                                        android:textSize="20sp"
                                        android:textStyle="bold"
                                        app:backgroundTint="@color/minecraft_green"
                                        app:cornerRadius="8dp" />

                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>

            </androidx.coordinatorlayout.widget.CoordinatorLayout>
        </FrameLayout> <!-- End fragment_container -->

        <!-- Menu Button -->
        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="48dp"
            android:layout_height="88dp"
            android:layout_gravity="start|top"
            android:layout_margin="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:elevation="8dp"
            android:src="@drawable/ic_menu"
            app:tint="@color/white"/>

        <!-- Splash Text - positioned at top right, above all content -->
        <TextView
            android:id="@+id/tv_splash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:layout_marginTop="200dp"
            android:layout_marginEnd="36dp"
            android:textColor="#CC8855"
            android:textSize="20sp"
            android:fontFamily="@font/uranus_pixel"
            android:elevation="50dp"
            android:maxWidth="150dp"
            android:gravity="end"
            android:rotation="-15" />

        <!-- Custom Bottom Navigation -->
        <LinearLayout
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:background="@android:color/transparent"
            android:elevation="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <include
                android:id="@+id/nav_item_converter"
                layout="@layout/layout_nav_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/nav_item_output"
                layout="@layout/layout_nav_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

    </FrameLayout>

    <!-- Navigation Drawer -->
    <include
        android:id="@+id/nav_drawer"
        layout="@layout/nav_drawer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"/>

</androidx.drawerlayout.widget.DrawerLayout>
